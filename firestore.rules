rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        getUserData().role == 'admin' || 
        (request.auth.token.email == "studentofficer2022@gmail.com" && request.auth.token.email_verified == true)
      );
    }
    
    function isTeacher() {
      return isAuthenticated() && getUserData().role == 'teacher';
    }

    function isValidString(val, min, max) {
      return val is string && val.size() >= min && val.size() <= max;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /notices/{noticeId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
        request.resource.data.senderId == request.auth.uid &&
        isValidString(request.resource.data.content, 0, 5000);
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.senderId == request.auth.uid);
    }

    match /materials/{materialId} {
      allow read: if isAuthenticated();
      allow create, delete: if isAdmin() || isTeacher();
    }

    match /photos/{photoId} {
      allow read: if isAuthenticated();
      allow create, delete: if isAdmin();
    }
  }
}
